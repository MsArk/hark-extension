{
  "manifest_version": 3,
  "name": "HARK",
  "version": "1.0.0",
  "description": "Captura automáticamente respuestas de red que coinciden con un patrón configurable. Útil para debugging y extracción de datos.",
  "permissions": ["debugger", "downloads", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HARK",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
